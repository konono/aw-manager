# aw-manager configuration
# Copy this file to .env and fill in the values.
# Values can also be passed as CLI flags or environment variables.
# Run `aw-manager serve --help` to see all options.

# --- Chat adapter (required) ---
# Which chat platform to connect to: "slack" or "discord"
CHAT_ADAPTER=slack

# --- Slack (required if CHAT_ADAPTER=slack) ---
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# --- Discord (required if CHAT_ADAPTER=discord) ---
# DISCORD_TOKEN=your-discord-bot-token

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- aw settings ---
# Profile name from .aw.yml for agent pods
AW_PROFILE=claude-k8s

# Namespace where agent pods are created
AW_NAMESPACE=aw

# Path to the aw binary
AW_BINARY=aw

# Directory containing .aw.yml (defaults to current directory)
# AW_CONFIG_DIR=

# AI tool to use: claude, codex, opencode, cursor
AW_TOOL=claude

# --- Server settings ---
# How long before idle agent pods are cleaned up
IDLE_TIMEOUT=1h

# Maximum number of concurrent message handlers (Pod creation + exec)
MAX_CONCURRENT=10

# Metrics server listen address
METRICS_ADDR=:9090
